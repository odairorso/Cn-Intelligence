# =============================================================================
# Fluxo de Caixa - Grupo CN — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NÃO committe o arquivo .env no repositório!

# ─── Banco de Dados PostgreSQL (Neon) ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-example.us-east-1.aws.neon.tech:5432/dbname?sslmode=require"

# ─── Segurança ────────────────────────────────────────────────────────────────
# Chave secreta usada para assinar e verificar tokens JWT
JWT_SECRET="mude-para-uma-chave-secreta-aleatoria-e-longa-aqui"
# Tempo de expiração do token JWT (ex: "24h", "7d")
JWT_EXPIRES_IN="24h"

# Token de segurança para proteger rotas sensíveis
SECURITY_TOKEN="mude-para-um-token-seguro-unico"

# ─── Gemini AI (extração de boletos) ──────────────────────────────────────────
GEMINI_API_KEY="sua-chave-gemini-aqui"
# Modelo Gemini preferido (fallback automático para gemini-2.0-flash → gemini-1.5-flash)
GEMINI_MODEL="gemini-2.0-flash"

# ─── Backup ───────────────────────────────────────────────────────────────────
# Token necessário para acessar a rota /api?route=export-backup
BACKUP_TOKEN="mude-para-um-token-de-backup-seguro"

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Token de segurança para APIs do frontend (deve corresponder a SECURITY_TOKEN)
VITE_CN_SECURITY_TOKEN="mude-para-um-token-seguro-unico"
# Token de backup usado no frontend para exportação (não é secreto, apenas identifica)
VITE_CN_BACKUP_TOKEN="mude-para-um-token-de-backup-seguro"
# URL base da API (para desenvolvimento local)
VITE_API_BASE_URL="/api"

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,https://seudominio.com.br"