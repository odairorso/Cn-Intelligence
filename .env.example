# Fluxo de Caixa - Grupo CN - Variaveis de ambiente
# Copie para .env e preencha com valores reais.
# Nunca commite o arquivo .env.

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Desempenho do pool de conexões. Recomendado 3-5 em produção, 1 em desenvolvimento local.
PG_POOL_MAX=3

# SSL do banco: em produção mantenha true. Apenas em desenvolvimento local com certificado
# autoassinado pode ser necessário definir como false (nunca em produção).
PG_SSL_REJECT_UNAUTHORIZED=true

# Autenticacao
APP_PASSWORD="troque-por-uma-senha-forte"
APP_UID="odair"
APP_EMAIL="user@cn.com"
JWT_SECRET="gere-um-segredo-aleatorio-longo"
JWT_EXPIRES_IN="7d"

# Token legado/compatibilidade. Nao e mais usado para autenticacao (apenas JWT e valido),
# mas ainda pode estar presente no frontend por compatibilidade. Pode ser removido futuramente.
SECURITY_TOKEN="gere-um-token-aleatorio-longo"
VITE_CN_SECURITY_TOKEN="gere-um-token-aleatorio-longo"

# Backup
# VITE_CN_BACKUP_TOKEN deve ter o mesmo valor de BACKUP_TOKEN.
BACKUP_TOKEN="gere-um-token-de-backup-aleatorio-longo"
VITE_CN_BACKUP_TOKEN="gere-um-token-de-backup-aleatorio-longo"

# Gemini AI para extracao de boletos
GEMINI_API_KEY="sua-chave-gemini-aqui"
GEMINI_MODEL="gemini-2.0-flash"

# Frontend/API
VITE_API_BASE_URL="/api"
DEFAULT_PAGE_SIZE=200

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://seudominio.com.br"
